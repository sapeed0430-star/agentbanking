{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentbanking.dev/schemas/receipt-1.0.0.schema.json",
  "title": "Audit Receipt 1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "report_id",
    "request_id",
    "agent_id",
    "operator_id",
    "schema_version",
    "issued_at",
    "verification_result",
    "policy_version",
    "report_digest",
    "signature",
    "timestamp_proof",
    "transparency_proof",
    "evidence_refs",
    "links"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "format": "uuid"
    },
    "report_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "request_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "agent_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "operator_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "verification_result": {
      "type": "string",
      "enum": ["pass", "warning", "fail"]
    },
    "policy_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "report_digest": {
      "$ref": "#/$defs/digest"
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "alg", "kid", "value"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["jws-compact", "jws-json"]
        },
        "alg": {
          "type": "string",
          "enum": ["EdDSA", "ES256"]
        },
        "kid": {
          "type": "string",
          "minLength": 3,
          "maxLength": 256
        },
        "value": {
          "type": "string",
          "minLength": 32
        }
      }
    },
    "timestamp_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tsa_name", "gen_time", "token_b64"],
      "properties": {
        "tsa_name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 128
        },
        "gen_time": {
          "type": "string",
          "format": "date-time"
        },
        "token_b64": {
          "type": "string",
          "minLength": 32
        }
      }
    },
    "transparency_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "log_id",
        "entry_id",
        "leaf_hash",
        "root_hash",
        "tree_size",
        "inclusion_proof"
      ],
      "properties": {
        "log_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128
        },
        "entry_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128
        },
        "leaf_hash": {
          "type": "string",
          "minLength": 32
        },
        "root_hash": {
          "type": "string",
          "minLength": 32
        },
        "tree_size": {
          "type": "integer",
          "minimum": 1
        },
        "inclusion_proof": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 32
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "uri", "digest"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["input", "execution_log", "output", "policy_snapshot"]
          },
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "digest": {
            "$ref": "#/$defs/digest"
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verify_url", "report_url"],
      "properties": {
        "verify_url": {
          "type": "string",
          "format": "uri"
        },
        "report_url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "value"],
      "properties": {
        "alg": {
          "type": "string",
          "enum": ["sha-256", "sha-512"]
        },
        "value": {
          "type": "string",
          "minLength": 32
        }
      }
    }
  }
}

# Server
PORT=3000
# In production, set 24+ chars and avoid placeholder strings.
AUDIT_ADMIN_TOKEN=local-admin-token
# Runtime proof uses this token in Authorization header.
# Recommendation: set the same value as AUDIT_ADMIN_TOKEN.
RUNTIME_PROOF_AUTH_TOKEN=local-admin-token

# Signer
AUDIT_SIGNER_MODE=mock
AUDIT_SIGNER_KID=dev-ed25519-key-2026q1
# PEM can be a single line with \n escaped.
AUDIT_SIGNER_PRIVATE_KEY_PEM=
# Proof-suite helper paths (used by scripts/run-proof-suite.sh)
AUDIT_SIGNER_PRIVATE_KEY_PATH=.keys/live-proof-ed25519-private.pem
AUDIT_SIGNER_PUBLIC_KEY_PATH=.keys/live-proof-ed25519-public.pem

# Timestamp (RFC3161)
AUDIT_TIMESTAMP_MODE=mock
AUDIT_TSA_NAME=rfc3161-tsa
AUDIT_RFC3161_ENDPOINT=
AUDIT_RFC3161_CA_CERT_PATH=

# Transparency log (Rekor)
AUDIT_TRANSPARENCY_MODE=mock
AUDIT_TRANSPARENCY_LOG_ID=rekor
AUDIT_REKOR_BASE_URL=
AUDIT_REKOR_PUBLIC_KEY_PEM_B64=
# source of rekor public key in proof-suite: signer-public-key-path | env
PROOF_SUITE_REKOR_KEY_SOURCE=signer-public-key-path

# Shared
AUDIT_PROOF_TIMEOUT_MS=10000
